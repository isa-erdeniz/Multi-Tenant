{
  "name": "garment-core",
  "version": "0.1.0",
  "private": true,
  "description": "Garment Core — satılabilir ürün / bağımsız servis iskeleti",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "npm run build && drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env ./scripts/seed-dev.ts",
    "db:create-api-key": "tsx --env-file=.env ./scripts/create-api-key.ts",
    "backup:db": "bash scripts/backup-postgres.sh",
    "backup:all": "bash scripts/backup-all.sh"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "express": "^4.21.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
